# MongoDB Cloud Atlas Configuration
# Replace <username>, <password>, <cluster-url>, and <database> with your actual values

# Example MongoDB Atlas Connection String:
# mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/examlms?retryWrites=true&w=majority

# For application.properties, update:
# spring.data.mongodb.uri=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
# spring.data.mongodb.database=examlms

# JWT Configuration (if not already set)
# jwt.secret=your-super-secret-key-at-least-256-bits-long
# jwt.expiration=86400000

# Server Port (optional)
# server.port=8080

# VNPay Payment Gateway Configuration
# Get credentials from VNPay Merchant Portal: https://sandbox.vnpayment.vn/
# vnpay.tmnCode=YOUR_VNPAY_TMN_CODE
# vnpay.hashSecret=YOUR_VNPAY_HASH_SECRET
# vnpay.payUrl=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# vnpay.returnUrl=http://localhost:3000/vnpay/return
